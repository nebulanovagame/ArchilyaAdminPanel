rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isActive != false;
    }

    function canBootstrapAdmin(userId) {
      return isAuthenticated()
        && userId == request.auth.uid
        && request.auth.token.email == 'admin@archilya.com'
        && request.resource.data.email == 'admin@archilya.com'
        && request.resource.data.role == 'super_admin'
        && request.resource.data.isActive == true;
    }

    function isBackendService() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'backend' ||
        request.auth.token.role == 'server'
      );
    }

    function hasMachineClaim() {
      return isAuthenticated() && request.auth.token.machineId is string;
    }

    function isLauncherForTarget() {
      return hasMachineClaim() && request.auth.token.machineId == resource.data.targetMachineId;
    }

    function launcherCanUpdateCommandDocument() {
      let changedKeys = request.resource.data.diff(resource.data).changedKeys();

      return changedKeys.hasOnly([
        'status',
        'processingStartedAt',
        'processedAt',
        'processedByMachineId',
        'resultUrl',
        'errorMessage'
      ])
      && request.resource.data.targetMachineId == resource.data.targetMachineId
      && request.resource.data.command == resource.data.command
      && request.resource.data.projectId == resource.data.projectId
      && request.resource.data.mapName == resource.data.mapName
      && request.resource.data.requestedBy == resource.data.requestedBy
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.expiresAt == resource.data.expiresAt
      && request.resource.data.status in ['processing', 'completed', 'failed', 'ignored']
      && (!('processedByMachineId' in request.resource.data)
          || request.resource.data.processedByMachineId == request.auth.token.machineId);
    }

    match /launcherCommands/{commandId} {
      allow create, delete: if isBackendService();

      allow get, list: if isAdmin() || isBackendService() || isLauncherForTarget();

      allow update: if isAdmin()
                    || isBackendService()
                    || (isLauncherForTarget() && launcherCanUpdateCommandDocument());
    }

    match /admins/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow create: if isAdmin() || canBootstrapAdmin(userId);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isAdmin() || isBackendService() || (isAuthenticated() && request.auth.uid == userId);
      allow create, update: if isAdmin() || isBackendService() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isAdmin() || isBackendService();
    }

    match /products/{productId} {
      allow read: if isAuthenticated() || isBackendService();
      allow write: if isAdmin() || isBackendService();
    }

    match /plans/{planId} {
      allow read, write: if isAdmin();
    }

    match /creditPackages/{packageId} {
      allow read, write: if isAdmin();
    }

    match /creditTransactions/{transactionId} {
      allow read, write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read, write: if isAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow read, write: if isAdmin();
    }

    match /launcherReleases/{releaseId} {
      allow read, write: if isAdmin();
    }

    match /machines/{machineId} {
      allow read, write: if isAdmin();
    }

    match /licenses/{licenseId} {
      allow read, write: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    function isProjectMember(data) {
      return isAuthenticated() && request.auth.uid in data.memberUids;
    }

    function isValidProjectCreate() {
      return isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.memberUids is list
        && request.auth.uid in request.resource.data.memberUids;
    }

    match /projects/{projectId} {
      allow get, list: if isBackendService() || isProjectMember(resource.data);
      allow create: if isBackendService() || isValidProjectCreate();
      allow update: if isBackendService() || isProjectMember(resource.data);
      allow delete: if isBackendService();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
