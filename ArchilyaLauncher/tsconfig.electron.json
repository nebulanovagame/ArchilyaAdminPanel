{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-electron",
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true
  },
  "include": ["electron/**/*", "src/main/**/*", "src/shared/**/*"],
  "exclude": ["src/main/main.ts"]
}