{
  "name": "archilya-admin-panel",
  "version": "1.0.0",
  "description": "Admin Panel for Archilya B2B Launcher",
  "main": "dist-electron/main.js",
  "author": "Archilya",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run electron:build:watch\" \"npm run electron:wait\"",
    "electron:build:watch": "tsc -p electron/tsconfig.json -w",
    "electron:wait": "wait-on tcp:5173 && electron .",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "dist": "npm run build && electron-builder",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.archilya.admin",
    "productName": "Archilya Admin Panel",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "clsx": "^2.1.0",
    "firebase": "^10.7.1",
    "lucide-react": "^0.309.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.1.3",
    "electron-builder": "^26.4.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "wait-on": "^7.2.0"
  }
}
