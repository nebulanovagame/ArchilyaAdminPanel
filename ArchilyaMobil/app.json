{
  "expo": {
    "name": "Archilya",
    "slug": "ArchilyaTelefonUygulamasi",
    "version": "0.1.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "archilya",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.archilya.app",
      "associatedDomains": ["applinks:archilya.com"],
      "infoPlist": {
        "NSCameraUsageDescription": "Archilya proje ve AI calismalari icin kamera ile gorsel yakalamaya ihtiyac duyar.",
        "NSMicrophoneUsageDescription": "Archilya video veya kamera tabanli sistem izinleri icin mikrofona erisim isteyebilir.",
        "NSLocationWhenInUseUsageDescription": "Archilya proje baglami ve cihaz ozellikleri icin konum izni isteyebilir.",
        "NSFaceIDUsageDescription": "Archilya hesap guvenligi icin Face ID kullanabilir."
      }
    },
    "android": {
      "package": "com.archilya.app",
      "googleServicesFile": "./android/app/google-services.json",
      "versionCode": 22,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "POST_NOTIFICATIONS",
        "INTERNET",
        "com.android.vending.BILLING"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "archilya.com" },
            { "scheme": "archilya" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0f1115",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      [
        "@sentry/react-native/expo",
        {
          "organization": "ORG_SLUG_BURAYA",
          "project": "PROJECT_SLUG_BURAYA"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Archilya proje ve AI calismalari icin galerideki gorsellere erisim ister.",
          "cameraPermission": "Archilya proje ve AI calismalari icin kameraya erisim ister."
        }
      ],
      "expo-notifications",
      "@sentry/react-native",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "315c513f-0492-42cf-9d6c-ce2dc89a528a"
      },
      "googleAuth": {
        "expoClientId": "782938691094-0m2snmr1a19jegdl6curi1teh3j8a5tp.apps.googleusercontent.com",
        "androidClientId": "782938691094-aovg2r9d70pnkk5j57hrj9j5mv5ln5to.apps.googleusercontent.com",
        "iosClientId": "",
        "webClientId": "782938691094-0m2snmr1a19jegdl6curi1teh3j8a5tp.apps.googleusercontent.com",
        "nativeScheme": "com.archilya.app"
      },
      "billing": {
        "checkoutUrl": "https://archilya.com/checkout"
      }
    },
    "owner": "nng-zgr"
  }
}
