rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function authUid() {
      return request.auth.uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(authUid()))
        && get(/databases/$(database)/documents/admins/$(authUid())).data.isActive != false;
    }

    function canBootstrapAdmin(uid) {
      return signedIn()
        && uid == authUid()
        && request.auth.token.email == 'admin@archilya.com'
        && request.resource.data.email == 'admin@archilya.com'
        && request.resource.data.role == 'super_admin'
        && request.resource.data.isActive == true;
    }

    function hasUid(listValue, uidValue) {
      return listValue is list && uidValue in listValue;
    }

    function workspaceReadable(data) {
      return signedIn() && data != null && (
        data.adminUid == authUid() || hasUid(data.memberUids, authUid())
      );
    }

    function isWorkspaceOwner(data) {
      return signedIn() && data != null && data.adminUid == authUid();
    }

    function isWorkspaceAdmin(data) {
      return signedIn() && data != null && (
        data.adminUid == authUid()
        || (data.members is list && data.members.hasAny([{'uid': authUid(), 'role': 'admin'}]))
      );
    }

    function isWorkspaceEditor(data) {
      return signedIn() && data != null && (
        data.adminUid == authUid()
        || (data.members is list && data.members.hasAny([{'uid': authUid(), 'role': 'admin'}]))
        || (data.members is list && data.members.hasAny([{'uid': authUid(), 'role': 'editor'}]))
      );
    }

    function docOwnedByCurrentUser(data) {
      return signedIn() && data != null && data.uid == authUid();
    }

    function createOwnedByCurrentUser() {
      return signedIn() && request.resource.data.uid == authUid();
    }

    function isProjectMember(data) {
      return signedIn() && data != null && hasUid(data.memberUids, authUid());
    }

    function requestProjectHasMember() {
      return signedIn() && request.resource.data.memberUids is list && authUid() in request.resource.data.memberUids;
    }

    function aiJobOwned(data) {
      return signedIn() && data != null && data.userId == authUid();
    }

    function requestAiJobOwned() {
      return signedIn() && request.resource.data.userId == authUid();
    }

    match /users/{uid} {
      allow read, write: if isAdmin() || (signedIn() && uid == authUid());

      match /aiStudioJobs/{jobId} {
        allow read: if signedIn() && uid == authUid();
        allow create, delete: if false;
        allow update: if signedIn() && uid == authUid()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["feedback", "updatedAt"]);
      }

      match /transactions/{txId} {
        allow read: if signedIn() && uid == authUid();
        allow create, update, delete: if false;
      }
    }

    match /admins/{uid} {
      allow read: if isAdmin() || (signedIn() && uid == authUid());
      allow create: if isAdmin() || canBootstrapAdmin(uid);
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read, write: if isAdmin();
    }

    match /plans/{planId} {
      allow read, write: if isAdmin();
    }

    match /creditPackages/{packageId} {
      allow read, write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read, write: if isAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow read, write: if isAdmin();
    }

    match /launcherReleases/{releaseId} {
      allow read, write: if isAdmin();
    }

    match /machines/{machineId} {
      allow read, write: if isAdmin();
    }

    match /launcherCommands/{commandId} {
      allow read, write: if isAdmin();
    }

    match /licenses/{licenseId} {
      allow read, write: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /workspaces/{workspaceId} {
      allow read: if workspaceReadable(resource.data)
        || (resource == null && signedIn() && request.resource.data.adminUid == authUid());
      allow create: if signedIn() && request.resource.data.adminUid == authUid();
      allow update: if isWorkspaceAdmin(resource.data);
      allow delete: if isWorkspaceOwner(resource.data);
    }

    match /workspaceInvites/{inviteId} {
      allow read: if signedIn() && (
        resource.data.fromUid == authUid()
        || resource.data.toUid == authUid()
        || resource.data.toEmail == request.auth.token.email
      );
      allow create: if signedIn() && (
        request.resource.data.fromUid == authUid()
        || get(/databases/$(database)/documents/workspaces/$(request.resource.data.workspaceId)).data.adminUid == authUid()
        || (get(/databases/$(database)/documents/workspaces/$(request.resource.data.workspaceId)).data.members is list
            && get(/databases/$(database)/documents/workspaces/$(request.resource.data.workspaceId)).data.members.hasAny([{'uid': authUid(), 'role': 'admin'}]))
      );
      allow update, delete: if signedIn() && (
        resource.data.fromUid == authUid()
        || resource.data.toUid == authUid()
        || resource.data.toEmail == request.auth.token.email
      );
    }

    match /projects/{projectId} {
      allow create: if requestProjectHasMember() && createOwnedByCurrentUser();
      allow read: if isProjectMember(resource.data);
      allow update: if isProjectMember(resource.data) && requestProjectHasMember();
      allow delete: if isProjectMember(resource.data);

      match /activityLogs/{logId} {
        allow read, write: if signedIn() && isProjectMember(get(/databases/$(database)/documents/projects/$(projectId)).data);
      }
    }

    match /creditTransactions/{transactionId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == authUid());
      allow create: if isAdmin() || (signedIn() && request.resource.data.userId == authUid());
      allow update, delete: if isAdmin();
    }

    match /trash/{trashId} {
      allow read, write: if signedIn() && (
        docOwnedByCurrentUser(resource.data)
        || createOwnedByCurrentUser()
      );
    }

    match /aiStudioJobs/{jobId} {
      allow create: if requestAiJobOwned();
      allow read: if aiJobOwned(resource.data);
      allow update, delete: if aiJobOwned(resource.data) && requestAiJobOwned();
    }

    match /renderSessions/{sessionId} {
      allow create: if signedIn() && request.resource.data.uid == authUid();
      allow read: if signedIn() && resource.data.uid == authUid();
      allow update: if signedIn() && resource.data.uid == authUid()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status", "scenes", "materials", "lightPreference", "annotations",
          "constraints", "metricLocks", "consistencyScore", "jobId",
          "outputImageUrls", "updatedAt"
        ]);
      allow delete: if signedIn() && resource.data.uid == authUid();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
