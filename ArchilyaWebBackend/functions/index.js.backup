    const allowedByEmail = normalizeEmail(invite.toEmail) === email;
    if (!allowedByUid && !allowedByEmail) {
      throw new HttpsError('permission-denied', 'Bu daveti reddetme yetkiniz yok.');
    }

    await inviteRef.update({
      status: 'declined',
