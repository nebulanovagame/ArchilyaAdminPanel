# ============================================================================
# Archilya WebBackend — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================================

# Supabase Configuration (ZORUNLU)
# Supabase self-hosted veya proje URL'i
SUPABASE_URL=https://supabase.archilya.com
# Service role key — asla frontend'e koymayın, sadece backend'de kullanılır
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# Express Server
PORT=8080

# CORS — hangi domain'lerden gelen isteklere izin verilecek
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://panel.archilya.com

# Sentry (Opsiyonel)
SENTRY_DSN=<sentry_dsn>

# Internal process secret — AI job processing endpoint koruması
INTERNAL_PROCESS_SECRET=<generate_random_secret>

# AI Studio billing mode: 'not_charged' (default) veya 'upstream' (external billing)
AI_STUDIO_BILLING_MODE=not_charged

# AI Studio processing config
AI_STUDIO_MAX_ATTEMPTS=3
AI_STUDIO_PROCESS_BATCH_SIZE=2

# GPT / Gemini API Keys
GEMINI_API_KEY=<gemini_api_key>
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
OPENAI_API_KEY=<openai_api_key>
REPLICATE_API_TOKEN=<replicate_api_token>

# R2 / Cloudflare Config
R2_ACCESS_KEY_ID=<r2_access_key>
R2_SECRET_ACCESS_KEY=<r2_secret_key>
R2_ENDPOINT=https://<account_id>.eu.r2.cloudflarestorage.com
R2_REGION=auto
R2_UPLOAD_URL_TTL_SECONDS=3600
R2_DOWNLOAD_URL_TTL_SECONDS=900

# Payment (Iyzico — opsiyonel, bu görevde kullanılmıyor)
IYZICO_API_KEY=sandbox-...
IYZICO_SECRET_KEY=...
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
